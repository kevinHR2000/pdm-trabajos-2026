<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity = "center"
    android:orientation = "vertical"
    android:layout_margin = "37dp"
    tools:context=".Resumen">
<!-- Visualmente los textos y botones no confundir los mismos id del otro .xml-->
    <TextView
        android:id = "@+id/txt_Nombre"
        android:layout_width = "match_parent"
        android:layout_height = "wrap_content"
        android:layout_marginBottom = "12dp"
        />

    <TextView
        android:id = "@+id/txt_Edad"
        android:layout_width = "match_parent"
        android:layout_height = "wrap_content"
        android:layout_marginBottom = "12dp"
        />

    <TextView
        android:id = "@+id/txt_Ciudad"
        android:layout_width = "match_parent"
        android:layout_height = "wrap_content"
        android:layout_marginBottom = "12dp"
        />

    <TextView
        android:id = "@+id/txt_Correo"
        android:layout_width = "match_parent"
        android:layout_height = "wrap_content"
        android:layout_marginBottom = "24dp"
        />

    <Button
        android:id = "@+id/btn_Confirmar"
        android:layout_width = "match_parent"
        android:layout_height = "wrap_content"
        android:text = "@string/btn_confirmar"
        android:layout_marginBottom="12dp"
        />

    <Button
        android:id = "@+id/btn_EditarTexto"
        android:layout_width = "match_parent"
        android:layout_height = "wrap_content"
        android:text = "@string/btn_editar_texto"
        />

</LinearLayout>